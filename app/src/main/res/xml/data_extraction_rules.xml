<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive vault data from cloud backup -->
        <exclude domain="sharedpref" path="helios_vault.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude sensitive vault data from device-to-device transfer -->
        <exclude domain="sharedpref" path="helios_vault.xml"/>
    </device-transfer>
</data-extraction-rules>
